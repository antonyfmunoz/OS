{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showThinkingSummaries": false,
  "alwaysThinkingEnabled": false,
  "model": "opus",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "console",
    "OTEL_LOGS_EXPORTER": "console",
    "MCP_CONNECTION_NONBLOCKING": "true",
    "ANTHROPIC_MODEL": "claude-opus-4-6"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(python3 *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(docker *)",
      "Bash(crontab *)",
      "Read(/opt/OS/**)",
      "Write(/opt/OS/**)",
      "Edit(/opt/OS/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(dd *)",
      "Read(/opt/OS/eos_ai/.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Create",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import eos_ai\" 2>/dev/null && echo '[Hook] imports: clean' || echo '[Hook] imports: CHECK FAILED'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Audit] Tool:PostToolUse File:'$CLAUDE_TOOL_INPUT_FILE_PATH' Time:'$(date -Iseconds) >> /opt/OS/logs/audit.log 2>/dev/null; true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; if [[ \"$f\" == *.py ]] && command -v ruff &>/dev/null; then ruff format \"$f\" --quiet 2>/dev/null && echo \"[Format] $f\" || true; fi"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys; sys.path.insert(0,'/opt/OS'); from eos_ai.context import load_context_from_env; ctx=load_context_from_env()\" 2>/dev/null && echo '[PreCompact] context saved' || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /opt/OS/scripts/session_start_context.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /opt/OS/scripts/check_stop_condition.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Failure] Tool:'$CLAUDE_TOOL_NAME' Time:'$(date -Iseconds) >> /opt/OS/logs/audit.log 2>/dev/null; true"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Task] Created: '$(echo $CLAUDE_TASK_TITLE | head -c 80)' Time:'$(date -Iseconds) >> /opt/OS/logs/audit.log 2>/dev/null; true"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Task] Completed: '$(echo $CLAUDE_TASK_TITLE | head -c 80)' Time:'$(date -Iseconds) >> /opt/OS/logs/audit.log 2>/dev/null; true"
          }
        ]
      }
    ]
  }
}
