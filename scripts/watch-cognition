#!/usr/bin/env bash
# watch-cognition — start the real-time cognition watcher.
#
# Runs scripts/watch_graph.py with sensible defaults. Intended to be
# run in a long-lived tmux pane on the VPS so the graph + palace stay
# fresh between manual update-graph invocations.
#
# Usage:
#   scripts/watch-cognition                     # incremental only
#   scripts/watch-cognition --with-overlay      # + graphify + merge + palace
#   scripts/watch-cognition --verbose           # log every event
#   scripts/watch-cognition --debounce 2500     # longer settle window
#
# Stop: Ctrl+C (SIGINT) — the watcher flushes pending batches and exits cleanly.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"

if ! python3 -c "import watchdog" >/dev/null 2>&1; then
  echo "watchdog not installed. Installing from scripts/requirements.txt..." >&2
  pip3 install --break-system-packages -r "$SCRIPT_DIR/requirements.txt" >&2
fi

exec python3 "$SCRIPT_DIR/watch_graph.py" "$@"
