#!/usr/bin/env bash
# post-merge — rebuild the codebase graph and palace after pulling code.
#
# Runs in the background so merges stay fast. Output goes to .graph-build.log
# at the repo root; check there if something looks off.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
LOG="$ROOT/.graph-build.log"

CHANGED=$(git diff --name-only HEAD@{1} HEAD | grep -E '\.(py|js|jsx|ts|tsx|sql)$' || true)
if [[ -z "$CHANGED" ]]; then
  exit 0
fi

(
  cd "$ROOT"
  echo "=== post-merge graph rebuild $(date -Iseconds) ===" >> "$LOG"
  python3 scripts/codebase_graph.py >> "$LOG" 2>&1 || echo "graph rebuild failed" >> "$LOG"
  python3 scripts/build_palace.py   >> "$LOG" 2>&1 || echo "palace rebuild failed" >> "$LOG"
  echo "done $(date -Iseconds)" >> "$LOG"
) &

disown
exit 0
