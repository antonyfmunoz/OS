#!/usr/bin/env bash
# pre-commit — warn when code changes are committed without a graph refresh.
#
# Blocks only on --strict. Otherwise prints a warning and lets the commit proceed
# so the founder is never stuck behind the hook.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(py|js|jsx|ts|tsx|sql)$' || true)

if [[ -z "$CHANGED" ]]; then
  exit 0
fi

python3 "$ROOT/scripts/session_bootstrap.py" --check >/dev/null 2>&1 || {
  echo "!! codebase graph is stale — changed code files will drift from the graph"
  echo "   run: scripts/update-graph && scripts/build_palace.py"
  echo "   (committing anyway — set EOS_GRAPH_STRICT=1 to block)"
  if [[ "${EOS_GRAPH_STRICT:-0}" == "1" ]]; then
    exit 1
  fi
}

exit 0
