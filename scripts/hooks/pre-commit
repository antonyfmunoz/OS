#!/usr/bin/env bash
# pre-commit — blocks commits that introduce type divergence.
#
# Canonical version: scripts/hooks/pre-commit
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or: scripts/install_divergence_gate.sh
#
# Checks staged Python files against substrate/canonical_types.py.
# If a new class definition shadows an existing canonical type,
# the commit is blocked with an actionable error message.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Only run if Python files are staged
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -z "$STAGED_PY" ]; then
    exit 0
fi

python3 "$REPO_ROOT/scripts/check_type_divergence.py"
