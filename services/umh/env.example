# UMH Environment Variables
# Copy to .env and fill in values. Never commit .env.

# === Ports ===
UMH_BACKEND_PORT=8093
UMH_BACKEND_HOST=0.0.0.0
UMH_FRONTEND_PORT=5173

# === URLs (defaults work for VPS local development) ===
UMH_BACKEND_URL=http://localhost:8093
UMH_FRONTEND_URL=http://localhost:5173
OPERATOR_API_URL=http://localhost:8091
OLLAMA_BASE_URL=http://localhost:11434

# === CORS (comma-separated extra origins beyond defaults) ===
# UMH_CORS_EXTRA_ORIGINS=http://custom-domain:3000

# === Model Routing Overrides ===
# Override any capability class's preferred provider via env var.
# Format: UMH_ROUTE_<CAPABILITY_NAME>=provider_symbol
#
# Example: force best reasoning to use Gemini instead of cc_sdk:
# UMH_ROUTE_BEST_CLOUD_REASONING=gemini_flash
#
# Example: force all local models to a specific Ollama model:
# UMH_ROUTE_LOCAL_FAST_MODEL=ollama_phi3

# === API Keys (managed by runtime/.env — do NOT duplicate) ===
# ANTHROPIC_API_KEY is loaded by runtime/model_router.py
# GOOGLE_API_KEY is loaded by runtime/model_router.py
# GROQ_API_KEY is loaded by runtime/model_router.py
# These should NOT be set here — they live in runtime/.env

# === Memory Promoter ===
# UMH_MEMORY_PATH=/opt/OS/umh_mvp/state/memories.json
# UMH_MEMORY_CONFIDENCE_THRESHOLD=0.7

# === Persona (user-facing AI identity — configured per deployment) ===
# UMH_PERSONA_NAME=
# UMH_PERSONA_TONE=neutral
# UMH_PERSONA_PACE=moderate
# UMH_PERSONA_FORMALITY=professional
# UMH_PERSONA_STYLE=tactical

# === Logging ===
# UMH_LOG_LEVEL=INFO
