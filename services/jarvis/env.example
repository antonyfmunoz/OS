# Jarvis Environment Variables
# Copy to .env and fill in values. Never commit .env.

# === Ports ===
JARVIS_BACKEND_PORT=8093
JARVIS_BACKEND_HOST=0.0.0.0
JARVIS_FRONTEND_PORT=5173

# === URLs (defaults work for VPS local development) ===
JARVIS_BACKEND_URL=http://localhost:8093
JARVIS_FRONTEND_URL=http://localhost:5173
OPERATOR_API_URL=http://localhost:8091
OLLAMA_BASE_URL=http://localhost:11434

# === CORS (comma-separated extra origins beyond defaults) ===
# JARVIS_CORS_EXTRA_ORIGINS=http://custom-domain:3000

# === Model Routing Overrides ===
# Override any capability class's preferred provider via env var.
# Format: JARVIS_ROUTE_<CAPABILITY_NAME>=provider_symbol
#
# Example: force best reasoning to use Gemini instead of cc_sdk:
# JARVIS_ROUTE_BEST_CLOUD_REASONING=gemini_flash
#
# Example: force all local models to a specific Ollama model:
# JARVIS_ROUTE_LOCAL_FAST_MODEL=ollama_phi3

# === API Keys (managed by runtime/.env — do NOT duplicate) ===
# ANTHROPIC_API_KEY is loaded by runtime/model_router.py
# GOOGLE_API_KEY is loaded by runtime/model_router.py
# GROQ_API_KEY is loaded by runtime/model_router.py
# These should NOT be set here — they live in runtime/.env

# === Memory Promoter ===
# JARVIS_MEMORY_PATH=/opt/OS/umh_mvp/state/memories.json
# JARVIS_MEMORY_CONFIDENCE_THRESHOLD=0.7

# === Logging ===
# JARVIS_LOG_LEVEL=INFO
