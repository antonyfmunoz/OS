{
  "_description": "Static adapter registry for local worker v1. UMH substrate.",
  "_phase": "96.8K",
  "_date": "2026-05-07",
  "workers": {
    "local_wsl_worker": {
      "environment_type": "local_wsl",
      "authority_domains": ["local_shell", "filesystem_relay"],
      "can_own_gui": false,
      "message_bus": "filesystem_json",
      "capabilities": ["ping", "relay_to_windows_adapter"]
    },
    "windows_interactive_desktop_relay": {
      "environment_type": "local_windows_desktop",
      "authority_domains": ["local_gui", "local_shell"],
      "can_own_gui": true,
      "message_bus": "filesystem_json",
      "capabilities": ["ping", "open_application_url"]
    }
  },
  "adapters": {
    "windows_interactive_desktop_relay": {
      "adapter_type": "gui_actuator",
      "environment_type": "local_windows_desktop",
      "authority_domain": "local_gui",
      "message_bus": "filesystem_json",
      "version": "v1",
      "capabilities": [
        {
          "capability_id": "ping",
          "action_type": "ping",
          "requires_gui": false,
          "requires_local_shell": false,
          "required_authority": "local_shell",
          "notes": ["Health check, no GUI needed"]
        },
        {
          "capability_id": "open_application_url",
          "action_type": "open_application_url",
          "requires_gui": true,
          "requires_local_shell": false,
          "required_authority": "local_gui",
          "notes": [
            "Launches Chrome via direct executable only",
            "Requires logged-in Windows desktop session",
            "Founder visual confirmation required"
          ]
        }
      ],
      "notes": [
        "Runs as PowerShell script in logged-in Windows session",
        "Communicates via filesystem JSON inbox/outbox",
        "PS 5.1 compatible"
      ]
    }
  }
}
